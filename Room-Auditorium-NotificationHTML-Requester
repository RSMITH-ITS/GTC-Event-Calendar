<table border="0" cellpadding="0" cellspacing="0" width="100%" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f4f4;">
    <tr>
        <td align="center" style="padding: 20px 0;">
            <table border="0" cellpadding="0" cellspacing="0" width="600" style="background-color: #ffffff; border-radius: 4px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                
                <!-- Header Image -->
                <tr>
                    <td align="center">
                        <img src="https://github.com/RSMITH-ITS/GTC-Event-Calendar/blob/main/GTC-Auditorium04.jpg?raw=true" alt="GTC" width="600" style="display: block; width: 100%;" />
                    </td>
                </tr>

                <!-- Subheader -->
                <tr>
                    <td bgcolor="#011E41" style="padding: 25px 40px; color: #ffffff;">
                        <div style="font-size: 12px; font-weight: bold; color: #91B119; text-transform: uppercase; letter-spacing: 1px;">Global Training Center</div>
                        <h1 style="margin: 4px 0 0 0; font-size: 22px; font-weight: bold;">Auditorium Event Registration</h1>
                    </td>
                </tr>

                <!-- Main Section -->
                <tr>
                    <td style="padding: 30px 40px;">
                        
                        <!-- NEW: Event Summary Section -->
                        <div style="font-size: 20px; font-weight: bold; color: #00426a; margin-bottom: 5px;">
                            @{formatDateTime(triggerBody()?['StartDate'], 'MMM dd')} | @{triggerBody()?['Title']}
                        </div>
                        <div style="margin-bottom: 25px;">
                            <span style="font-weight: bold; color: #011E41; font-size: 14px; text-transform: uppercase;"> </span>
                            <span style="color: #C70087; font-size: 14px;">Thank you for completing the form. Just a reminder that your request will remain tentative until after your discovery call with the AV team. Please reach out to CRE with any questions.</span>
                        </div>

                        <!-- Section 1: Event Details -->
                        <div style="font-size: 18px; font-weight: bold; color: #00426a; padding: 10px 0; border-bottom: 2px solid #91B119; margin-bottom: 10px; text-transform: uppercase;">Event Details</div>
                        <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 20px;">
                            <tr><td style="width:30%; font-weight:bold; color:#011E41; padding:8px 0; font-size:14px; border-bottom:1px solid #f0f0f0;">Start Date</td><td style="padding:8px 0 8px 15px; font-size:14px; border-bottom:1px solid #f0f0f0;">@{if(empty(triggerBody()?['StartDate']), 'N/A', convertTimeZone(triggerBody()?['StartDate'], 'UTC', 'Pacific Standard Time', 'yyyy-MM-dd hh:mm tt'))}</td></tr>
                            <tr><td style="font-weight:bold; color:#011E41; padding:8px 0; font-size:14px; border-bottom:1px solid #f0f0f0;">End Date</td><td style="padding:8px 0 8px 15px; font-size:14px; border-bottom:1px solid #f0f0f0;">@{if(empty(triggerBody()?['OData__EndDate']), 'N/A', convertTimeZone(triggerBody()?['OData__EndDate'], 'UTC', 'Pacific Standard Time', 'yyyy-MM-dd hh:mm tt'))}</td></tr>
                            <tr><td style="font-weight:bold; color:#011E41; padding:8px 0; font-size:14px; border-bottom:1px solid #f0f0f0;">Setup Time</td><td style="padding:8px 0 8px 15px; font-size:14px; border-bottom:1px solid #f0f0f0;">@{if(empty(triggerBody()?['SetupTime']), 'N/A', convertTimeZone(triggerBody()?['SetupTime'], 'UTC', 'Pacific Standard Time', 'yyyy-MM-dd hh:mm tt'))}</td></tr>
                            <tr><td style="font-weight:bold; color:#011E41; padding:8px 0; font-size:14px; border-bottom:1px solid #f0f0f0;">Attendees</td><td style="padding:8px 0 8px 15px; font-size:14px; border-bottom:1px solid #f0f0f0;">@{string(triggerBody()?['Attendees'])}</td></tr>
                            <tr><td style="font-weight:bold; color:#011E41; padding:8px 0; font-size:14px; border-bottom:1px solid #f0f0f0;">VIP</td><td style="padding:8px 0 8px 15px; font-size:14px; border-bottom:1px solid #f0f0f0;">@{variables('varVIPListHTML')}</td></tr>
                        </table>

                        <!-- Section 2: Services -->
                        <div style="font-size: 18px; font-weight: bold; color: #00426a; padding: 10px 0; border-bottom: 2px solid #91B119; margin-bottom: 10px; text-transform: uppercase;">Services</div>
                        <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 20px;">
                            <tr><td style="width:30%; font-weight:bold; color:#011E41; padding:8px 0; font-size:14px; border-bottom:1px solid #f0f0f0;">AV</td><td style="padding:8px 0 8px 15px; font-size:14px; border-bottom:1px solid #f0f0f0;">@{coalesce(triggerBody()?['AV/Value'], 'None')}</td></tr>
                            <tr><td style="font-weight:bold; color:#011E41; padding:8px 0; font-size:14px; border-bottom:1px solid #f0f0f0;">AV Discovery</td><td style="padding:8px 0 8px 15px; font-size:14px; border-bottom:1px solid #f0f0f0;">@{coalesce(triggerBody()?['AVDiscovery/Value'], 'None')}</td></tr>
                            <tr><td style="font-weight:bold; color:#011E41; padding:8px 0; font-size:14px; border-bottom:1px solid #f0f0f0;">Catering</td><td style="padding:8px 0 8px 15px; font-size:14px; border-bottom:1px solid #f0f0f0;">@{coalesce(triggerBody()?['Catering/Value'], 'None')}</td></tr>
                            <tr><td style="font-weight:bold; color:#011E41; padding:8px 0; font-size:14px; border-bottom:1px solid #f0f0f0;">Layout</td><td style="padding:8px 0 8px 15px; font-size:14px; border-bottom:1px solid #f0f0f0;">@{coalesce(triggerBody()?['Layout/Value'], 'None')}</td></tr>
                            <tr><td style="font-weight:bold; color:#011E41; padding:8px 0; font-size:14px; border-bottom:1px solid #f0f0f0;">Facilities</td><td style="padding:8px 0 8px 15px; font-size:14px; border-bottom:1px solid #f0f0f0;">@{coalesce(triggerBody()?['Facilities/Value'], 'None')}</td></tr>
                        </table>

                        <!-- Section 3: Additional Notes -->
                        <div style="font-size: 18px; font-weight: bold; color: #00426a; padding: 10px 0; border-bottom: 2px solid #91B119; margin-bottom: 10px; text-transform: uppercase;">Additional Notes</div>
                        <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 30px;">
                            <tr><td style="width:30%; font-weight:bold; color:#011E41; padding:8px 0; font-size:14px; border-bottom:1px solid #f0f0f0;">Furniture</td><td style="padding:8px 0 8px 15px; font-size:14px; border-bottom:1px solid #f0f0f0;">@{coalesce(triggerBody()?['Furniture'], 'None')}</td></tr>
                            <tr><td style="font-weight:bold; color:#011E41; padding:8px 0; font-size:14px; border-bottom:1px solid #f0f0f0;">Notes</td><td style="padding:8px 0 8px 15px; font-size:14px; border-bottom:1px solid #f0f0f0;">@{coalesce(triggerBody()?['Notes'], 'None')}</td></tr>
                        </table>
                        
<!-- SharePoint Buttons -->
<table border="0" cellspacing="0" cellpadding="0" width="100%">
    <tr>
        <td align="center">
            <table border="0" cellspacing="0" cellpadding="0">
                <tr>
                    <!-- New Button: Meetings & Events -->
                    <td align="center" bgcolor="#0076a3" style="border-radius: 4px; padding: 12px 25px;">
                        <a href="https://alaskaair.sharepoint.com/sites/CorporateRealEstate/SitePages/Meetings%20and%20Events.aspx" target="_blank" style="font-size: 16px; font-weight: bold; color: #ffffff; text-decoration: none; display: inline-block;">
                            <table border="0" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td style="padding-right: 10px;">
                                        <img src="https://github.com/RSMITH-ITS/GTC-Event-Calendar/blob/main/sharepoint-white-64.png?raw=true
g" width="18" height="18" style="display: block;" />
                                    </td>
                                    <td style="color: #ffffff; font-size: 16px; font-weight: bold;">Meetings & Events</td>
                                </tr>
                            </table>
                        </a>
                    </td>

                    <!-- Spacer -->
                    <td width="20"></td>

                    <!-- Original Button: My Events -->
                    <td align="center" bgcolor="#0076a3" style="border-radius: 4px; padding: 12px 25px;">
                        <a href="https://alaskaair.sharepoint.com/sites/CorporateRealEstate/SitePages/Meetings%20and%20Events%20My%20Events.aspx" target="_blank" style="font-size: 16px; font-weight: bold; color: #ffffff; text-decoration: none; display: inline-block;">
                            <table border="0" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td style="padding-right: 10px;">
                                        <img src="https://github.com/RSMITH-ITS/GTC-Event-Calendar/blob/main/sharepoint-white-64.png?raw=true
" width="18" height="18" style="display: block;" />
                                    </td>
                                    <td style="color: #ffffff; font-size: 16px; font-weight: bold;">My Events</td>
                                </tr>
                            </table>
                        </a>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>






                <!-- Footer -->
                <tr>
                    <td bgcolor="#f8f8f8" style="padding: 20px 40px; border-top: 1px solid #eeeeee; font-size: 12px; color: #666666;">
                        <strong>Alaska Airlines</strong> | Global Training Center
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
