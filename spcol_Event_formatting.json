{
  "$schema": "https://developer.microsoft.com/json-schemas/sp/v2/column-formatting.schema.json",
  "elmType": "div",
  "txtContent": "@currentField",
  "style": {
    "cursor": "pointer",
    "color": "#0078d4"
  },
  "customCardProps": {
    "openOnEvent": "hover",
    "directionalHint": "rightCenter",
    "formatter": {
      "elmType": "div",
      "style": {
        "padding": "20px",
        "min-width": "320px",
        "background-color": "white",
        "border-radius": "4px",
        "box-shadow": "0 2px 15px rgba(0,0,0,0.15)",
        "display": "flex",
        "flex-direction": "column",
        "gap": "12px"
      },
      "children": [
        {
          "elmType": "div",
          "style": {
            "font-size": "12px",
            "color": "#605e5c",
            "font-weight": "400"
          },
          "txtContent": "[$Title]"
        },
        {
          "elmType": "div",
          "style": {
            "display": "flex",
            "align-items": "center",
            "gap": "10px"
          },
          "children": [
            {
              "elmType": "span",
              "attributes": {
                "iconName": "ConferenceRoom",
                "class": "ms-Icon--ConferenceRoom"
              },
              "style": {
                "font-size": "24px",
                "color": "#0078d4"
              }
            },
            {
              "elmType": "div",
              "style": {
                "font-size": "20px",
                "font-weight": "700",
                "color": "#323130"
              },
              "txtContent": "[$Room]"
            }
          ]
        },
        {
          "elmType": "div",
          "style": {
            "display": "flex",
            "flex-direction": "column",
            "gap": "8px",
            "margin-top": "8px"
          },
          "children": [
            {
              "elmType": "div",
              "style": {
                "display": "flex"
              },
              "children": [
                {
                  "elmType": "div",
                  "txtContent": "Status",
                  "style": {
                    "width": "100px",
                    "font-weight": "bold",
                    "color": "#323130"
                  }
                },
                {
                  "elmType": "div",
                  "txtContent": "[$Status]",
                  "style": {
                    "color": "#605e5c"
                  }
                }
              ]
            },
            {
              "elmType": "div",
              "style": {
                "display": "flex"
              },
              "children": [
                {
                  "elmType": "div",
                  "txtContent": "Start Date",
                  "style": {
                    "width": "100px",
                    "font-weight": "bold",
                    "color": "#323130"
                  }
                },
                {
                  "elmType": "div",
                  "txtContent": "=if([$StartDate], toLocaleDateString([$StartDate]), '—')",
                  "style": {
                    "color": "#605e5c"
                  }
                }
              ]
            },
            {
              "elmType": "div",
              "style": {
                "display": "=if([$VIP] == true || [$VIP] == 'Yes', 'flex', 'none')"
              },
              "children": [
                {
                  "elmType": "div",
                  "txtContent": "VIP",
                  "style": {
                    "width": "100px",
                    "font-weight": "bold",
                    "color": "#323130"
                  }
                },
                {
                  "elmType": "span",
                  "attributes": {
                    "iconName": "Flag"
                  },
                  "style": {
                    "color": "#d83b01",
                    "font-size": "14px"
                  }
                }
              ]
            },
            {
              "elmType": "div",
              "style": {
                "display": "flex",
                "align-items": "center"
              },
              "children": [
                {
                  "elmType": "div",
                  "txtContent": "Vendor",
                  "style": {
                    "width": "100px",
                    "font-weight": "bold",
                    "color": "#323130"
                  }
                },
                {
                  "elmType": "div",
                  "style": {
                    "display": "flex",
                    "gap": "8px"
                  },
                  "children": [
                    {
                      "elmType": "span",
                      "attributes": {
                        "iconName": "Headset",
                        "title": "AV"
                      },
                      "style": {
                        "display": "=if([$AV], 'block', 'none')",
                        "color": "#0078d4"
                      }
                    },
                    {
                      "elmType": "span",
                      "attributes": {
                        "iconName": "EatDrink",
                        "title": "Catering"
                      },
                      "style": {
                        "display": "=if([$Catering], 'block', 'none')",
                        "color": "#107c10"
                      }
                    },
                    {
                      "elmType": "span",
                      "attributes": {
                        "iconName": "People",
                        "title": "Facilities"
                      },
                      "style": {
                        "display": "=if([$Facilities], 'block', 'none')",
                        "color": "#605e5c"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  }
}