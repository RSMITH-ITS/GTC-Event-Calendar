{
  "$schema": "https://developer.microsoft.com/json-schemas/sp/v2/column-formatting.schema.json",
  "elmType": "div",
  "style": {
    "display": "flex",
    "align-items": "center",
    "justify-content": "flex-start",
    "width": "100%"
  },
  "children": [
    {
      "elmType": "span",
      "style": {
        "cursor": "pointer",
        "color": "#0078d4",
        "font-size": "16px",
        "padding-right": "8px"
      },
      "attributes": {
        "iconName": "Info",
        "class": "ms-Icon--Info"
      },
      "customCardProps": {
        "openOnEvent": "hover",
        "directionalHint": "rightCenter",
        "isBeakVisible": true,
        "formatter": {
          "elmType": "div",
          "style": {
            "padding": "20px",
            "min-width": "320px",
            "background-color": "white",
            "border-radius": "4px",
            "box-shadow": "0 2px 15px rgba(0,0,0,0.15)",
            "display": "flex",
            "flex-direction": "column",
            "gap": "12px"
          },
          "children": [
            {
              "elmType": "div",
              "style": {
                "font-size": "12px",
                "color": "#605e5c",
                "font-weight": "400"
              },
              "txtContent": "[$Title]"
            },
            {
              "elmType": "div",
              "style": {
                "display": "flex",
                "align-items": "center",
                "gap": "10px"
              },
              "children": [
                {
                  "elmType": "span",
                  "attributes": {
                    "iconName": "ConferenceRoom"
                  },
                  "style": {
                    "font-size": "24px",
                    "color": "#0078d4"
                  }
                },
                {
                  "elmType": "div",
                  "style": {
                    "font-size": "20px",
                    "font-weight": "700",
                    "color": "#323130"
                  },
                  "txtContent": "[$Room]"
                }
              ]
            },
            {
              "elmType": "div",
              "style": {
                "display": "flex",
                "flex-direction": "column",
                "gap": "8px",
                "margin-top": "8px"
              },
              "children": [
                {
                  "elmType": "div",
                  "style": {
                    "display": "flex"
                  },
                  "children": [
                    {
                      "elmType": "div",
                      "txtContent": "Status",
                      "style": {
                        "width": "110px",
                        "font-weight": "bold",
                        "color": "#323130"
                      }
                    },
                    {
                      "elmType": "div",
                      "txtContent": "[$Status]",
                      "style": {
                        "color": "#605e5c"
                      }
                    }
                  ]
                },
                {
                  "elmType": "div",
                  "style": {
                    "display": "flex"
                  },
                  "children": [
                    {
                      "elmType": "div",
                      "txtContent": "Start Date",
                      "style": {
                        "width": "110px",
                        "font-weight": "bold",
                        "color": "#323130"
                      }
                    },
                    {
                      "elmType": "div",
                      "txtContent": "=if([$StartDate], toLocaleString([$StartDate]), '—')",
                      "style": {
                        "color": "#605e5c"
                      }
                    }
                  ]
                },
                {
                  "elmType": "div",
                  "style": {
                    "display": "flex"
                  },
                  "children": [
                    {
                      "elmType": "div",
                      "txtContent": "End Date",
                      "style": {
                        "width": "110px",
                        "font-weight": "bold",
                        "color": "#323130"
                      }
                    },
                    {
                      "elmType": "div",
                      "txtContent": "=if([$EndDate], toLocaleString([$EndDate]), '—')",
                      "style": {
                        "color": "#605e5c"
                      }
                    }
                  ]
                },
                {
                  "elmType": "div",
                  "style": {
                    "display": "=if([$SetupTime], 'flex', 'none')"
                  },
                  "children": [
                    {
                      "elmType": "div",
                      "txtContent": "SetupTime",
                      "style": {
                        "width": "110px",
                        "font-weight": "bold",
                        "color": "#323130"
                      }
                    },
                    {
                      "elmType": "div",
                      "txtContent": "[$SetupTime]",
                      "style": {
                        "color": "#605e5c"
                      }
                    }
                  ]
                },
                {
                  "elmType": "div",
                  "style": {
                    "display": "flex",
                    "align-items": "center"
                  },
                  "children": [
                    {
                      "elmType": "div",
                      "txtContent": "Services",
                      "style": {
                        "width": "110px",
                        "font-weight": "bold",
                        "color": "#323130"
                      }
                    },
                    {
                      "elmType": "div",
                      "style": {
                        "display": "flex",
                        "gap": "8px"
                      },
                      "children": [
                        {
                          "elmType": "span",
                          "attributes": {
                            "iconName": "Headset",
                            "title": "AV Required"
                          },
                          "style": {
                            "display": "=if(indexOf([$Icon2], 'AV') >= 0 || [$Icon2] == 'ALL', 'inline-block', 'none')",
                            "font-size": "18px",
                            "color": "#0078D4"
                          }
                        },
                        {
                          "elmType": "span",
                          "attributes": {
                            "iconName": "EatDrink",
                            "title": "Catering Required"
                          },
                          "style": {
                            "display": "=if(indexOf([$Icon2], 'CAT') >= 0 || [$Icon2] == 'ALL', 'inline-block', 'none')",
                            "font-size": "18px",
                            "color": "#107C10"
                          }
                        },
                        {
                          "elmType": "span",
                          "attributes": {
                            "iconName": "People",
                            "title": "Facilities Required"
                          },
                          "style": {
                            "display": "=if(indexOf([$Icon2], 'FAC') >= 0 || [$Icon2] == 'ALL', 'inline-block', 'none')",
                            "font-size": "18px",
                            "color": "#8E562E"
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    },
    {
      "elmType": "div",
      "txtContent": "@currentField",
      "style": {
        "color": "#0078d4",
        "overflow": "hidden",
        "text-overflow": "ellipsis",
        "white-space": "nowrap"
      }
    }
  ]
}
