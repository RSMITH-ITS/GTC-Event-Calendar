<div class="event-card">
    <!-- Header Section -->
    <div class="card-header">
        <div class="header-content">
            <div class="glass-overlay">
                <div class="sub-brand">Global Training Center</div>
                <div class="main-title"> @{concat(outputs('Compose_|_Room_Name'), 'Event ', variables('varActionType'))}</div>
            </div>
        </div>
    </div>

    <!-- Main Content Section -->
    <div class="card-body">
        <div class="event-summary">
            @{formatDateTime(triggerOutputs()?['body/start'], 'MMM dd')} | 
        </div>
        
        <div class="label">Contacts</div>
        <div class="contact-list">
            @{triggerOutputs()?['body/organizer']}
        </div>
    </div>

    <!-- Buttons Section -->
    <div class="content-footer">
        <a href="@{variables('varEventSPLink')}" class="link-button">
            <table class="link-table">
                <tr>
                    <td class="icon-cell">
                        <img src="https://res-1.cdn.office.net/files/fabric-cdn-prod_20230815.002/assets/brand-icons/product/svg/sharepoint_32x1.svg" class="icon-img" alt="SP">
                    </td>
                    <td class="text-cell">Event Planning Link | SharePoint</td>
                </tr>
            </table>
        </a>

        <a href="https://outlook.office.com/calendar" class="link-button">
            <table class="link-table">
                <tr>
                    <td class="icon-cell">
                        <img src="https://res-1.cdn.office.net/files/fabric-cdn-prod_20230815.002/assets/brand-icons/product/svg/outlook_32x1.svg" class="icon-img" alt="Outlook">
                    </td>
                    <td class="text-cell">[Room] Calendar | Outlook</td>
                </tr>
            </table>
        </a>
    </div>
</div>
