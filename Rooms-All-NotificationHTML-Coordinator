<table border="0" cellpadding="0" cellspacing="0" width="100%" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f4f4;">
    <tr>
        <td align="center" style="padding: 20px 0;">
            <table border="0" cellpadding="0" cellspacing="0" width="600" style="background-color: #ffffff; border-radius: 4px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                
                <!-- Header Image -->
                <tr>
                    <td align="center">
                        <img src="https://alaskaair.sharepoint.com/sites/CorporateRealEstate/SiteAssets/GTCEventsApp/GTC-exterior04.png" alt="GTC" width="600" style="display: block; width: 100%; max-width: 600px;" />
                    </td>
                </tr>

                <!-- Dark Subheader -->
                <tr>
                    <td bgcolor="#011E41" style="padding: 25px 40px; color: #ffffff;">
                        <div style="margin: 0; font-size: 14px; font-weight: bold; color: #91B119; text-transform: uppercase; letter-spacing: 1px; line-height: 1;">Global Training Center</div>
                        <h1 style="margin: 4px 0 0 0; font-size: 24px; font-weight: bold; line-height: 1.1; color: #ffffff;">@{variables('varRoomName')} | Event @{variables('varActionType')}</h1>
                    </td>
                </tr>

                <!-- Main Content Section -->
                <tr>
                    <td style="padding: 40px; color: #333333;">
                        
                        <!-- Event Summary Section with Null Check -->
                        <div style="font-size: 20px; font-weight: bold; color: #00426a; margin-bottom: 5px;">
                            @{if(empty(variables('varStartDate')), 'N/A', formatDateTime(variables('varStartDate'), 'MMM dd'))} | @{variables('varEventTitle')}
                        </div>
                        <div style="margin-bottom: 25px;">
                            <span style="font-weight: bold; color: #011E41; font-size: 14px; text-transform: uppercase;">Contact: @{variables('varOrganizerLink')}</span>
                            <span style="color: #333333; font-size: 14px;">@{variables('varContactName')}</span>
                        </div>

                        <div style="font-size: 18px; font-weight: bold; color: #00426a; padding: 10px 0; border-bottom: 2px solid #91B119; margin-bottom: 20px; text-transform: uppercase;">Event Resources</div>
                        
                        <!-- Two Button Layout -->
                        <table border="0" cellpadding="0" cellspacing="0" width="100%">
                            <tr>
                                <!-- Button 1 -->
                                <td width="48%" align="left" style="padding-bottom: 10px;">
                                    <table border="0" cellspacing="0" cellpadding="0" width="100%">
                                        <tr>
                                            <td align="center" bgcolor="#0076a3" style="border-radius: 4px;">
                                                <a href="@{variables('varItemSPLink')}" target="_blank" style="font-family: 'Segoe UI', Tahoma, Arial, sans-serif; font-size: 14px; font-weight: bold; color: #ffffff; text-decoration: none; display: block; padding: 12px 10px;">
                                                    <img src="https://alaskaair.sharepoint.com/sites/CorporateRealEstate/SiteAssets/GTCEventsApp/sharepoint-white-64.png" width="18" height="18" style="margin-right: 8px; border: 0; vertical-align: middle;" />
                                                    <span style="vertical-align: middle;">Event Details</span>
                                                </a>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                                
                                <td width="4%">&nbsp;</td> <!-- Spacer -->

                                <!-- Button 2 (Fixed Link and Font) -->
                                <td width="48%" align="right" style="padding-bottom: 10px;">
                                    <table border="0" cellspacing="0" cellpadding="0" width="100%">
                                        <tr>
                                            <td align="center" bgcolor="#0076a3" style="border-radius: 4px;">
                                                <a href="@{variables('varCalendarLink')}" target="_blank" style="font-family: 'Segoe UI', Tahoma, Arial, sans-serif; font-size: 14px; font-weight: bold; color: #ffffff; text-decoration: none; display: block; padding: 12px 10px;">
                                                    <img src="https://alaskaair.sharepoint.com/sites/CorporateRealEstate/SiteAssets/GTCEventsApp/outlook-calendar-white-64.png" width="18" height="18" style="margin-right: 8px; border: 0; vertical-align: middle;" />
                                                    <span style="vertical-align: middle;">@{variables('varRoomName')} Calendar</span>
                                                </a>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <!-- Footer Section -->
                <tr>
                    <td bgcolor="#f8f8f8" style="padding: 30px 40px; border-top: 1px solid #eeeeee;">
                        <table border="0" cellpadding="0" cellspacing="0" width="100%">
                            <tr>
                                <td style="font-size: 12px; color: #666666; line-height: 1.5;">
                                    <strong style="color: #00426a;">Alaska Airlines</strong><br />
                                    Global Training Center
                                </td>
                                <td align="right" style="font-size: 12px; color: #666666;">
                                    <a href="https://alaskaair.sharepoint.com/sites/CorporateRealEstate/SitePages/Meetings%20and%20Events.aspx" style="color: #0076a3; text-decoration: none;">Meetings and Events</a>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
